# Exemplo de configuração para sincronização LinkedIn
# Copie este arquivo para .env e preencha com seus dados

# LinkedIn Profile ID (seu username no LinkedIn)
# Exemplo: brenoasantana (do URL: linkedin.com/in/brenoasantana/)
LINKEDIN_PROFILE_ID=brenoasantana

# RapidAPI Key (opcional - para dados em tempo real)
# Obtenha em: https://rapidapi.com/linkedin-data-linkedin-data-default/api/linkedin-data2
# RAPIDAPI_KEY=sua_chave_aqui

# GitHub Token (usado apenas em CI/CD, não necessário localmente)
# GITHUB_TOKEN=seu_token_aqui

# Intervalo de sincronização (em horas)
# Padrão: 24 (diDaily)
SYNC_INTERVAL_HOURS=24

# Ativar sincronização automática
ENABLE_AUTO_SYNC=true

# Ativar modo debug (mais verboso)
DEBUG_MODE=false
